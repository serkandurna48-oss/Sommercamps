# ============================================================
# KSV Baunatal Sommercamp Backend – Umgebungsvariablen
# Kopieren als .env und echte Werte eintragen.
# Diese Datei enthält KEINE echten Secrets und ist im Repo.
# ============================================================

# Supabase – PostgreSQL Connection String
# Zu finden unter: Supabase → Settings → Database → Connection string → URI
# Variante: Transaction Pooler, Port 6543
DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-1-eu-west-2.pooler.supabase.com:6543/postgres

# Admin-Passwort für /admin/login im Browser
# Wähle ein starkes Passwort, gib es deinem Kollegen – kein API-Key nötig.
ADMIN_PASSWORD=hier-ein-starkes-passwort-setzen

# Geheimschlüssel zum Signieren der JWT-Session-Tokens
# Generieren mit: openssl rand -hex 32
JWT_SECRET=hier-einen-langen-zufaelligen-string-setzen

# Gültigkeit eines Session-Tokens in Stunden (optional, Standard: 24)
# TOKEN_EXPIRE_HOURS=24

# Zusätzliche erlaubte CORS-Origins (kommagetrennt)
# Für Produktion: Vercel-URL des Frontends eintragen
# CORS_ORIGINS_EXTRA=https://deine-app.vercel.app

# ── Stripe ──────────────────────────────────────────────────
# Stripe Secret Key (Dashboard → Developers → API keys)
# Test-Schlüssel beginnen mit sk_test_, Live-Schlüssel mit sk_live_
# STRIPE_SECRET_KEY=sk_test_...

# Stripe Webhook Secret (Dashboard → Webhooks → dein Endpoint → Signing secret)
# Wird zur Signatur-Verifikation eingehender Webhook-Events genutzt.
# STRIPE_WEBHOOK_SECRET=whsec_...

# Campbeitrag in Cent (muss mit dem Preis im Stripe-Produkt übereinstimmen)
# Beispiel: 14900 = 149,00 €
# Wird von GET /config ausgeliefert; fehlt dieser Wert, liefert /config und /checkout HTTP 503.
# STRIPE_PRICE_CENTS=14900

# ── E-Mail (Brevo) ───────────────────────────────────────────
# Brevo API Key (app.brevo.com → Account → SMTP & API → API Keys)
# BREVO_API_KEY=xkeysib-...

# Absender-E-Mail-Adresse (muss in Brevo verifiziert sein)
# SENDER_EMAIL=info@ksv-baunatal.de

# Absendername (erscheint im Posteingang)
# SENDER_NAME=Fußballschule KSV Baunatal

# Kontakt-E-Mail im Mailtext (für Rückfragen der Eltern)
# CONTACT_EMAIL=info@ksv-baunatal.de

# ── Frontend-URL ─────────────────────────────────────────────
# Vollständige URL des Frontends – für Stripe-Redirect nach Checkout
# Lokal: http://localhost:3000 | Produktion: https://deine-app.vercel.app
# FRONTEND_URL=http://localhost:3000

# ── Zusätzliche CORS-Origins ────────────────────────────────
# Für Produktion: Vercel-URL des Frontends eintragen (kommagetrennt)
# CORS_ORIGINS_EXTRA=https://deine-app.vercel.app
